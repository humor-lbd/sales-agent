# 文件作用：提供后端环境变量模板，方便新环境快速补齐配置。
# 阅读这个文件时，建议先看分组，再看每个配置项会影响哪一层能力。

# 应用基础配置：控制服务名称、端口和默认数据库行为。
APP_NAME=jc-sales-agent-python
APP_PORT=8088
# 鉴权配置：控制是否开启登录拦截和访客模式。
AUTH_ENABLED=false
# JWT 配置：决定令牌签发密钥和过期时间。
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=1440

# MySQL 配置：决定后端读取哪个数据库实例。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=jc_sales_agent_py
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-mysql-password
DB_BOOTSTRAP_ENABLED=true
DB_BOOTSTRAP_WITH_SEED=true
DB_BOOTSTRAP_RESEED=false
DB_BOOTSTRAP_FAIL_FAST=true

# Redis 配置：决定缓存是否启用以及连接位置。
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 模型配置：控制调用哪个模型及其网关参数。
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=replace-with-your-qwen-api-key
OPENAI_MODEL=qwen-max
OPENAI_TIMEOUT_SECONDS=60
AGENT_MAX_TOOL_CALLS=6
AGENT_TRACE_ENABLED=true
AGENT_MEMORY_FOLLOWUP_LIMIT=10
AGENT_MEMORY_WINDOW_MESSAGES=20
AGENT_MEMORY_LLM_SUMMARY_ENABLED=true
AGENT_MEMORY_LLM_SUMMARY_MODEL=
AGENT_MEMORY_LLM_SUMMARY_TRIGGER_MESSAGES=8
AGENT_MEMORY_SUMMARY_MESSAGES=6
AGENT_MEMORY_SUMMARY_CHARS=80

# 异常检测阈值：控制销量下降、退款率等规则的灵敏度。
ANOMALY_THRESHOLD_DAYS=5
TREND_DROP_THRESHOLD=0.3
